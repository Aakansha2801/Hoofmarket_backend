# ── Bubble.io ────────────────────────────────────────────────
# Required: Bubble API token for listing sync (read + write)
API_TOKEN=your_bubble_api_token_here

# ── Optional: override defaults ─────────────────────────────
# TESTING_MODE=true          # true → 30 min interval, false → 24 h
# SCRAPE_INTERVAL_HOURS=6    # override both TESTING_MODE defaults
# LOG_DIR=/app/logs          # Docker default; local runs use ./logs
